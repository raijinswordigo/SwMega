<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">

            <solid android:color="#303030"/>

            <corners android:radius="4dp"/>

            <stroke
                android:width="3dp"
                android:color="#4EA8FF"/>

            <padding
                android:left="12dp"
                android:right="12dp"
                android:top="10dp"
                android:bottom="10dp"/>
        </shape>
    </item>

    <!-- Pressed -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">

            <solid android:color="#383838"/>

            <corners android:radius="4dp"/>

            <stroke
                android:width="3dp"
                android:color="#6F6F6F"/>

            <padding
                android:left="12dp"
                android:right="12dp"
                android:top="10dp"
                android:bottom="10dp"/>
        </shape>
    </item>

    <!-- Default -->
    <item>
        <shape android:shape="rectangle">

            <solid android:color="#2A2A2A"/>

            <corners android:radius="4dp"/>

            <stroke
                android:width="3dp"
                android:color="#555555"/>

            <padding
                android:left="12dp"
                android:right="12dp"
                android:top="10dp"
                android:bottom="10dp"/>
        </shape>
    </item>

</selector>